{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data stored in both Firebase and Supabase.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "coverURL": { "type": "string" },
        "bio": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "creator", "admin"] },
        "isPremium": { "type": "boolean" },
        "borderStyle": { "type": "string" },
        "pix_key": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username"]
    },
    "Service": {
      "title": "Service Card",
      "description": "Services offered by creators.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "coverUrl": { "type": "string" },
        "coverType": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "title", "price"]
    },
    "Post": {
      "title": "Feed Post",
      "description": "Content posted to the social feed.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string" },
        "type": { "type": "string", "enum": ["public", "private"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" }
      },
      "required": ["authorId", "content"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "Messaging thread between two users.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "last_message": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Chat Message",
      "description": "Individual message in a chat.",
      "type": "object",
      "properties": {
        "chat_id": { "type": "string" },
        "sender_id": { "type": "string" },
        "text": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "Alert for user activity.",
      "type": "object",
      "properties": {
        "recipient_id": { "type": "string" },
        "sender_id": { "type": "string" },
        "sender_name": { "type": "string" },
        "type": { "type": "string", "enum": ["follow", "like", "comment", "message", "order"] },
        "message": { "type": "string" },
        "post_id": { "type": "string" },
        "read": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Follow": {
      "title": "User Follow Relation",
      "description": "Tracks who is following whom.",
      "type": "object",
      "properties": {
        "follower_id": { "type": "string" },
        "following_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Like": {
      "title": "Post Like",
      "description": "Indicates a user liked a post.",
      "type": "object",
      "properties": {
        "post_id": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Comment": {
      "title": "Post Comment",
      "description": "Comment on a feed post.",
      "type": "object",
      "properties": {
        "post_id": { "type": "string" },
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "user_photo": { "type": "string" },
        "text": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "SecretContent": {
      "title": "Secret Content",
      "description": "Locked content that must be purchased.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Purchase transaction.",
      "type": "object",
      "properties": {
        "buyer_id": { "type": "string" },
        "seller_id": { "type": "string" },
        "item_id": { "type": "string" },
        "item_type": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Withdrawal": {
      "title": "Withdrawal Request",
      "description": "Creator withdrawal request.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "pix_key": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Individual user profile by UID."
    },
    "services/{serviceId}": {
      "schema": { "$ref": "#/entities/Service" },
      "description": "Service listings."
    },
    "posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Feed posts."
    },
    "chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chat metadata."
    },
    "messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Chat messages."
    },
    "notifications/{notifId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "User notifications."
    },
    "follows/{followId}": {
      "schema": { "$ref": "#/entities/Follow" },
      "description": "Follow relationships."
    },
    "likes/{likeId}": {
      "schema": { "$ref": "#/entities/Like" },
      "description": "Likes on posts."
    },
    "comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on posts."
    },
    "secret_contents/{contentId}": {
      "schema": { "$ref": "#/entities/SecretContent" },
      "description": "Purchasable secret content."
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Transactions."
    },
    "withdrawals/{withdrawId}": {
      "schema": { "$ref": "#/entities/Withdrawal" },
      "description": "Withdrawal requests."
    },
    "admins/{userId}": {
      "schema": { "type": "object", "properties": { "id": { "type": "string" } } },
      "description": "Admin list."
    }
  }
}
