rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'dweminem@gmail.com' ||
        request.auth.token.email == 'contato.packzinhu@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny EVERYTHING
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // VALIDATION HELPERS
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'email']) &&
             data.username is string && data.username.size() <= 50 &&
             data.email is string && data.email.size() <= 100;
    }

    function isValidPost(data) {
      return data.authorId == request.auth.uid &&
             ('content' in data && data.content is string && data.content.size() <= 5000) &&
             ('createdAt' in data && data.createdAt is string) &&
             (!('mediaType' in data) || data.mediaType is string) &&
             (!('mediaUrl' in data) || data.mediaUrl is string) &&
             ('authorName' in data) &&
             ('authorRole' in data);
    }

    function isValidComment(data) {
      return data.post_id is string && data.author_id is string && data.text is string;
    }

    function isValidLike(data) { return (data.userId == request.auth.uid || data.user_id == request.auth.uid); }

    function isValidFollow(data) { return (data.followerId == request.auth.uid || data.follower_id == request.auth.uid); }

    // -------------------------------------------------------------------------
    // SECRET CONTENTS
    // -------------------------------------------------------------------------
    match /secret_contents/{contentId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // -------------------------------------------------------------------------
    // USERS (PROFILES)
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && (
        isAdmin() || 
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'coverURL', 'bio', 'username', 'links', 'mercadoPagoId', 'balance', 'totalRating', 'reviewCount', 'rating', 'followersCount', 'followingCount'])
      );
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // SERVICES
    // -------------------------------------------------------------------------
    match /services/{serviceId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.sellerId == request.auth.uid || 
        resource.data.authorId == request.auth.uid || 
        isAdmin() ||
        incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'commentsCount', 'reviewsCount', 'rating', 'totalReviews', 'totalRating', 'reviewCount'])
      );
      allow delete: if (isSignedIn() && (resource.data.sellerId == request.auth.uid || resource.data.authorId == request.auth.uid || isAdmin()));
    }

    // -------------------------------------------------------------------------
    // POSTS
    // -------------------------------------------------------------------------
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidPost(incoming());
      allow update: if isSignedIn() && (
        (resource.data.authorId == request.auth.uid || isAdmin()) && (
          isAdmin() || 
          incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mediaUrl', 'thumbnailUrl', 'type', 'likesCount', 'commentsCount', 'updatedAt', 'tags'])
        ) ||
        // Public counters updates
        incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'commentsCount'])
      );
      allow delete: if (isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin()));
    }

    // -------------------------------------------------------------------------
    // REVIEWS
    // -------------------------------------------------------------------------
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // BANK ACCOUNTS
    // -------------------------------------------------------------------------
    match /bank_accounts/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // -------------------------------------------------------------------------
    // CHATS & MESSAGES
    // -------------------------------------------------------------------------
    match /chats/{chatId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in incoming().participants);
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.participants);
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/chats/$(resource.data.chat_id)) && 
         request.auth.uid in get(/databases/$(database)/documents/chats/$(resource.data.chat_id)).data.participants)
      );
      allow create: if isSignedIn() && (
        incoming().sender_id == request.auth.uid &&
        exists(/databases/$(database)/documents/chats/$(incoming().chat_id)) && 
        request.auth.uid in get(/databases/$(database)/documents/chats/$(incoming().chat_id)).data.participants
      );
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.sender_id == request.auth.uid);
    }

    // -------------------------------------------------------------------------
    // USER SETTINGS
    // -------------------------------------------------------------------------
    match /user_settings/{userId} {
      allow read, write: if isAdmin() || isOwner(userId);
    }

    // -------------------------------------------------------------------------
    // NOTIFICATION SETTINGS
    // -------------------------------------------------------------------------
    match /notification_settings/{userId} {
      allow read, write: if isAdmin() || isOwner(userId);
    }

    // -------------------------------------------------------------------------
    // NOTIFICATIONS
    // -------------------------------------------------------------------------
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.recipient_id == request.auth.uid || 
        resource.data.recipient_id == 'global'
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || resource.data.recipient_id == request.auth.uid);
      allow delete: if isSignedIn() && (isAdmin() || resource.data.recipient_id == request.auth.uid);
    }

    // -------------------------------------------------------------------------
    // FOLLOWS & LIKES & COMMENTS & BOOKMARKS
    // -------------------------------------------------------------------------
    match /follows/{id} {
      allow read: if true;
      allow create: if isSignedIn() && isValidFollow(incoming());
      allow delete: if isSignedIn() && (isAdmin() || resource.data.follower_id == request.auth.uid);
    }

    match /followers/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /likes/{id} {
      allow read: if true;
      allow create: if isSignedIn() && isValidLike(incoming());
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /comments/{id} {
      allow read: if true;
      allow create: if isSignedIn() && isValidComment(incoming());
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /bookmarks/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // -------------------------------------------------------------------------
    // ORDERS & FINANCE
    // -------------------------------------------------------------------------
    match /orders/{id} {
      allow read: if isAdmin() || (isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid || 
        resource.data.buyer_id == request.auth.uid || 
        resource.data.seller_id == request.auth.uid
      ));
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /withdrawal_requests/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /withdrawals/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.user_id == request.auth.uid);
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /hotcoin_transactions/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // SYSTEM & ADMIN
    // -------------------------------------------------------------------------
    match /site_emails/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system_stats/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ads/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /customAds/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /webpush_subscriptions/{id} {
      allow read: if isAdmin();
      allow write: if true;
    }

    match /admins/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
