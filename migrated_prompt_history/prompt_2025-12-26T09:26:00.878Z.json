           <\\/script>\n              <script type=\"text/javascript\" src=\"//www.highperformanceformat.com/636867b6f7ed261cff82839bf0d0203e/invoke.js\"><\\/script>\n            </body>\n          </html>\n        `;\n        return (\n          <div className=\"flex justify-center items-center w-full my-2\">\n             <iframe srcDoc={srcDoc} width=\"320\" height=\"50\" frameBorder=\"0\" scrolling=\"no\" style={{border:'none', overflow:'hidden'}} title=\"Adsterra Footer\"></iframe>\n          </div>\n        );\n      };\n\n      const App = () => {\n        const targetUrl = \"https://drive.google.com/drive/folders/1uM874OGQh65CwBzaQpym9RFbcnXadw_F?usp=drive_link\";\n        const [clickCount, setClickCount] = useState(0);\n        const REQUIRED_CLICKS = 2;\n        const [onlineCount, setOnlineCount] = useState(45);\n        const [toast, setToast] = useState(null);\n\n        useEffect(() => {\n          const interval = setInterval(() => {\n             setOnlineCount(prev => Math.min(100, Math.max(7, prev + Math.floor(Math.random() * 10) - 5)));\n          }, 4000);\n\n          const names = [\"Ricardo - SP\", \"João - MG\", \"Carlos - RJ\", \"Felipe - RS\", \"Ana - SP\"];\n          const showToast = () => {\n             setToast({ name: names[Math.floor(Math.random() * names.length)], action: \"liberou o pack\" });\n             setTimeout(() => setToast(null), 4000);\n          };\n          const toastInterval = setInterval(showToast, 12000);\n\n          return () => {\n            clearInterval(interval);\n            clearInterval(toastInterval);\n          };\n        }, []);\n\n        const triggerPopunderWindow = () => {\n          // Tenta abrir em uma nova janela de popup, não apenas uma aba, se o navegador permitir\n          const popUrl = \"https://al5sm.com/tag.min.js?zone=10264515\"; // Usando a URL da tag ou placeholder\n          window.open(popUrl, '_blank', 'width=400,height=400,left=100,top=100,resizable=yes,scrollbars=yes');\n        };\n\n        const handleButtonClick = (e) => {\n          if (clickCount < REQUIRED_CLICKS) {\n            e.preventDefault();\n            triggerPopunderWindow();\n            setClickCount(prev => prev + 1);\n          }\n        };\n\n        const isUnlocked = clickCount >= REQUIRED_CLICKS;\n\n        return (\n          <div className=\"relative min-h-[100dvh] w-full flex flex-col bg-[#000000] overflow-x-hidden selection:bg-purple-500/30\">\n            \n            {/* Ambient Glows */}\n            <div className=\"fixed top-[-10%] left-[-10%] w-[500px] h-[500px] bg-purple-900/20 rounded-full blur-[120px] pointer-events-none\"></div>\n            <div className=\"fixed bottom-[-10%] right-[-10%] w-[500px] h-[500px] bg-green-900/20 rounded-full blur-[120px] pointer-events-none\"></div>\n            <div className=\"fixed inset-0 bg-[url('https://www.transparenttextures.com/patterns/dark-matter.png')] opacity-20 pointer-events-none\"></div>\n\n            {toast && (\n                <div className=\"fixed top-4 right-4 z-50 animate-slide-in-top\">\n                    <div className=\"flex items-center gap-3 bg-zinc-900/80 backdrop-blur-lg border border-purple-500/30 px-4 py-3 rounded-2xl shadow-2xl\">\n                        <div className=\"bg-green-500/20 p-1.5 rounded-full\"><ShieldCheckIcon className=\"w-4 h-4 text-green-400\" /></div>\n                        <div className=\"flex flex-col\"><span className=\"text-white text-xs font-bold\">{toast.name}</span><span className=\"text-gray-400 text-[10px]\">{toast.action}</span></div>\n                    </div>\n                </div>\n            )}\n\n            <main className=\"relative z-10 flex flex-col items-center justify-center w-full max-w-2xl mx-auto px-6 py-16 gap-8 flex-grow\">\n              \n              <header className=\"text-center space-y-4 animate-fade-in-up\">\n                <h1 className=\"text-5xl md:text-6xl font-black tracking-tighter text-white\">\n                  AMOSTRA <br/>\n                  <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-purple-400 via-green-400 to-yellow-400 animate-gradient-flow\">GRÁTIS</span>\n                </h1>\n                <p className=\"text-zinc-400 text-sm md:text-base font-medium\">Conteúdo exclusivo liberado no Drive.<br/>Aguarde a liberação do acesso.</p>\n              </header>\n\n              <div className=\"flex items-center gap-2 animate-fade-in-up\" style={{animationDelay: '0.1s'}}>\n                 <ShieldCheckIcon className=\"w-5 h-5 text-green-500\" />\n                 <span className=\"text-[11px] font-bold text-green-500 tracking-[0.2em] uppercase\">Conexão Segura & Verificada</span>\n              </div>\n\n              {/* Main Button Container */}\n              <div className=\"relative w-full group animate-fade-in-up\" style={{animationDelay: '0.2s'}}>\n                {!isUnlocked && <div className=\"absolute -inset-1 bg-gradient-to-r from-purple-600 to-green-600 rounded-3xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200\"></div>}\n                \n                <a \n                  href={isUnlocked ? targetUrl : \"#\"} \n                  onClick={handleButtonClick}\n                  target={isUnlocked ? \"_blank\" : \"_self\"}\n                  rel=\"noopener noreferrer\"\n                  className=\"relative block w-full\"\n                >\n                  <button className={`w-full py-6 md:py-8 rounded-2xl border-2 transition-all duration-500 flex flex-col items-center justify-center gap-2 overflow-hidden ${\n                    isUnlocked \n                    ? \"bg-green-600/10 border-green-500 shadow-[0_0_30px_rgba(34,197,94,0.3)] hover:bg-green-600/20\" \n                    : \"bg-zinc-900 border-purple-500/50 hover:border-purple-400 shadow-[0_0_30px_rgba(168,85,247,0.2)]\"\n                  }`}>\n                    <span className={`text-2xl md:text-3xl font-black tracking-tight uppercase ${isUnlocked ? 'text-green-400' : 'text-white'}`}>\n                      {clickCount === 0 ? \"CLIQUE AQUI\" : clickCount === 1 ? \"FALTA 1 CLIQUE\" : \"ACESSAR AGORA\"}\n                    </span>\n                    <span className=\"text-[10px] md:text-xs font-bold tracking-widest text-zinc-500 uppercase\">\n                      {isUnlocked ? \"Link Liberado com sucesso\" : \"Amostra Grátis Exclusiva\"}\n                    </span>\n                    \n                    {/* Progress Bar Background */}\n                    {!isUnlocked && (\n                        <div className=\"absolute bottom-0 left-0 h-1 bg-purple-500/20 w-full\">\n                            <div className=\"h-full bg-gradient-to-r from-purple-500 to-green-500 transition-all duration-500\" style={{width: `${(clickCount/REQUIRED_CLICKS)*100}%`}}></div>\n                        </div>\n                    )}\n                  </button>\n                </a>\n              </div>\n\n              {/* Status Section */}\n              <div className=\"w-full space-y-4 animate-fade-in-up\" style={{animationDelay: '0.3s'}}>\n                <div className=\"flex flex-wrap items-center justify-center gap-3\">\n                   <div className=\"flex items-center gap-2 px-4 py-2 bg-yellow-500/10 border border-yellow-500/20 rounded-full\">\n                      <LockIcon isOpen={isUnlocked} className={`w-4 h-4 ${isUnlocked ? 'text-green-500' : 'text-yellow-500'}`} />\n                      <span className=\"text-xs font-bold text-yellow-500 uppercase\">{isUnlocked ? 'Acesso Liberado' : 'Clique 2x para Liberar'}</span>\n                   </div>\n                   <div className=\"flex items-center gap-2 px-4 py-2 bg-orange-500/10 border border-orange-500/20 rounded-full\">\n                      <span className=\"relative flex h-2 w-2\"><span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75\"></span><span className=\"relative inline-flex rounded-full h-2 w-2 bg-orange-500\"></span></span>\n                      <span className=\"text-xs font-bold text-orange-500 uppercase\">{onlineCount} Online</span>\n                   </div>\n                </div>\n\n                <p className=\"text-center text-[10px] text-zinc-600 font-bold uppercase tracking-widest max-w-xs mx-auto leading-relaxed\">\n                  Ao clicar, anúncios serão abertos em novas janelas. Basta fechá-los e clicar novamente para liberar o link do Drive.\n                </p>\n              </div>\n\n            </main>\n\n            <footer className=\"relative z-10 w-full py-8 mt-auto border-t border-zinc-900 bg-black/80 backdrop-blur-xl\">\n               <FooterAdsterraBanner />\n               <div className=\"flex flex-col items-center justify-center gap-4 px-6 text-center\">\n                  <div className=\"text-[11px] text-zinc-500 font-medium\">\n                     © 2025 • Criado por <span className=\"text-purple-400 font-bold\">Magrinha.Sapeka</span>\n                  </div>\n                  <div className=\"h-[2px] w-full max-w-md bg-gradient-to-r from-transparent via-purple-500 to-transparent opacity-20\"></div>\n               </div>\n            </footer>\n          </div>\n        );\n      };\n\n      const root = ReactDOM.createRoot(document.getElementById('root'));\n      root.render(<App />);\n    </script>\n  </body>\n</html>"
